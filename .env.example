# OpenRouter (https://openrouter.ai/keys )
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-******
OPENROUTER_MODEL=openai/gpt-4o

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=*****@gmail.com
SMTP_PASSWORD=****

# Recipients (choose one style):
# A) Legacy: one list, mail language follows --language (default zh)
NOTIFICATION_TO=*****@outlook.com
# B) Split: Chinese vs English templates + links (comma-separated). If set, NOTIFICATION_TO is ignored for routing.
# NOTIFICATION_TO_ZH=alice@corp.cn,bob@corp.cn
# NOTIFICATION_TO_EN=carol@corp.com

# GitHub
GITHUB_PAGES_URL=https://*******.github.io/TomatoNews

# Skip pipeline on Sat/Sun in NEWS_DATE_TZ. Set false to run any day locally.
SKIP_WEEKENDS=true

# Calendar for "today" / previous business day (IANA). Unset = DEFAULT_NEWS_DATE_TZ in scripts/config.py
# NEWS_DATE_TZ=Asia/Shanghai

# RSS URL
RSS_URL=https://news.smol.ai/rss.xml

# Image generation settings
ENABLE_IMAGE_GENERATION = true